# Copy this file to .env and fill only the providers you use.

# Recommended default. DeepSeek uses its Anthropic-compatible endpoint.
GUMU_DEEPSEEK_API_BASE=https://api.deepseek.com/anthropic
GUMU_DEEPSEEK_API_KEY=
GUMU_DEEPSEEK_MODEL=deepseek-v4-pro

# Optional right.codes shared key. Used by --provider openai and --provider anthropic when provider-specific keys are empty.
GUMU_RIGHT_CODES_API_KEY=

# Default OpenAI-compatible endpoint. Change this if you use another /responses-compatible service.
GUMU_OPENAI_API_BASE=https://www.right.codes/codex/v1
GUMU_OPENAI_API_KEY=
GUMU_OPENAI_MODEL=gpt-5.4

# Default Anthropic-compatible endpoint. Can reuse GUMU_RIGHT_CODES_API_KEY when your gateway shares one key.
GUMU_ANTHROPIC_API_BASE=https://www.right.codes/claude/v1
GUMU_ANTHROPIC_API_KEY=
GUMU_ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional comma-separated extra env names to redact from traces and reports.
GUMU_SECRET_ENV_NAMES=
